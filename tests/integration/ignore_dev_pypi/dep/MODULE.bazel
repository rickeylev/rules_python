module(name = "ignore_dev_pypi_dep")
# Conflicting non-dev dependency

bazel_dep(name = "rules_python")
local_path_override(
    module_name = "rules_python",
    path = "../../../..",
)

# Dev-only usage with conflicting name
pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip", dev_dependency = True)
pip.parse(
    hub_name = "pypi",
    python_version = "3.11",
    requirements_lock = "//:requirements_lock.txt",
)
use_repo(pip, "pypi")
