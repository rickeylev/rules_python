load("@bazel_skylib//rules:common_settings.bzl", "string_flag")
load("@rules_python//python:py_test.bzl", "py_test")

py_test(
    name = "test",
    srcs = ["test.py"],
    # Make this test better respect pyenv
    env_inherit = ["PYENV_VERSION"],
)

# Config setting for the in-build local toolchain
config_setting(
    name = "is_py_local_in_build",
    flag_values = {
        ":py": "local_in_build",
    },
)

# Config setting for the system (non-in-build) local toolchain
config_setting(
    name = "is_py_local_system",
    flag_values = {
        ":py": "local_system",
    },
)

# Flag to select the Python runtime mode for tests in this package
# Users can set e.g. `--//tests/integration/local_toolchains:py=local_in_build`
# The .bazelrc file for this test sets it to "local_in_build" by default.
string_flag(
    name = "py",
    build_setting_default = "local_in_build", # Default to testing the new in-build mode
)
