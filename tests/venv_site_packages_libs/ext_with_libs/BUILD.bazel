load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_shared_library.bzl", "cc_shared_library")
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("//python:py_library.bzl", "py_library")
load("//tests/support:copy_file.bzl", "copy_file_to_dir")

package(
    default_visibility = ["//visibility:public"],
)

cc_library(
    name = "increment_impl",
    srcs = ["increment.c"],
    deps = [":increment_headers"],
)

cc_library(
    name = "increment_headers",
    hdrs = ["increment.h"],
)

cc_shared_library(
    name = "increment",
    user_link_flags = select({
        "@platforms//os:osx": [
            # Needed so that DT_NEEDED=libincrement.dylib can find
            # this shared library
            "-Wl,-install_name,@rpath/libincrement.dylib",
        ],
        "//conditions:default": [],
    }),
    deps = [":increment_impl"],
)

cc_library(
    name = "adder_impl",
    srcs = ["adder.c"],
    deps = [
        ":increment_headers",
        "@rules_python//python/cc:current_py_cc_headers",
    ] + select({
        "@platforms//os:windows": ["@rules_python//python/cc:current_py_cc_libs"],
        "//conditions:default": [],
    }),
    alwayslink = True,
)

# On Windows, cc_shared_library does not correctly link against the Python 
# import library when it is provided via current_py_cc_libs.
# Using cc_binary with linkshared = True works around this.
# We also link increment_impl statically here to avoid cc_shared_library 
# dependency issues in cc_binary.
cc_binary(
    name = "adder_windows",
    deps = [
        ":adder_impl",
        ":increment_impl",
        "@rules_python//python/cc:current_py_cc_libs",
    ],
    linkshared = True,
    tags = ["manual"],
)

cc_shared_library(
    name = "adder_unix",
    dynamic_deps = [":increment"],
    shared_lib_name = "adder.so",
    tags = ["manual"],
    user_link_flags = select({
        "@platforms//os:osx": [
            "-Wl,-rpath,@loader_path/libs",
            "-undefined",
            "dynamic_lookup",
            "-Wl,-exported_symbol",
            "-Wl,_PyInit_adder",
        ],
        # Assume linux default
        "//conditions:default": [
            "-Wl,-rpath,$ORIGIN/libs",
        ],
    }),
    deps = [":adder_impl"],
)

alias(
    name = "adder",
    actual = select({
        "@platforms//os:windows": ":adder_windows",
        "//conditions:default": ":adder_unix",
    }),
    tags = ["manual"],
)

copy_file_to_dir(
    name = "relocate_adder",
    src = ":adder",
    out_dir = "site-packages/ext_with_libs",
    tags = ["manual"],
)

copy_file_to_dir(
    name = "relocate_increment",
    src = ":increment",
    out_dir = "site-packages/ext_with_libs/libs",
    tags = ["manual"],
)

py_library(
    name = "ext_with_libs",
    srcs = glob(["site-packages/**/*.py"]),
    data = [
        ":relocate_adder",
        ":relocate_increment",
    ],
    experimental_venvs_site_packages = "//python/config_settings:venvs_site_packages",
    imports = ["site-packages"],
    tags = ["manual"],
)
