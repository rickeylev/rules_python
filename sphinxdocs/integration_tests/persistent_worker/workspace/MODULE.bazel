module(version = "0.0.0")

bazel_dep(name = "sphinxdocs", version = "0.0.0")
local_path_override(
    module_name = "sphinxdocs",
    path = "../../..",
)

bazel_dep(name = "rules_python", version = "2.2.0")

uv = use_extension("@rules_python//python/uv:uv.bzl", "uv", dev_dependency = True)
uv.configure(
    version = "0.11.3",
)

dev_pip = use_extension(
    "@rules_python//python/extensions:pip.bzl",
    "pip",
    dev_dependency = True,
)
dev_pip.parse(
    hub_name = "dev_pip",
    python_version = "3.11",
    # Workaround: requirements_lock is required by rules_python 2.2.0 even when uv_lock is set.
    # It is ignored at runtime, so we pass uv.lock to satisfy validation.
    requirements_lock = "//:dev/uv.lock",
    uv_lock = "//:dev/uv.lock",
)
use_repo(dev_pip, "dev_pip")

bazel_dep(name = "bazel_skylib", version = "1.8.2")
